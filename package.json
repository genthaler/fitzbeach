{
  "name": "fitzbeach",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "clean": "shx rm -rf .parcel-cache frontend/.parcel-cache frontend/dist frontend/dist-book frontend/elm-stuff",
    "backend:build": "stack --stack-yaml backend/stack.yaml --stack-root \"$PWD/backend/.stack-root\" build",
    "backend:codegen": "stack --stack-yaml backend/stack.yaml --stack-root \"$PWD/backend/.stack-root\" run fitzbeach-backend-codegen",
    "backend:ghci": "stack --stack-yaml backend/stack.yaml --stack-root \"$PWD/backend/.stack-root\" ghci",
    "backend:ghci:main": "stack --stack-yaml backend/stack.yaml --stack-root \"$PWD/backend/.stack-root\" ghci --ghci-options -e --ghci-options :main",
    "backend:run": "stack --stack-yaml backend/stack.yaml --stack-root \"$PWD/backend/.stack-root\" run",
    "backend:test": "stack --stack-yaml backend/stack.yaml --stack-root \"$PWD/backend/.stack-root\" test",
    "backend:watch": "stack --stack-yaml backend/stack.yaml --stack-root \"$PWD/backend/.stack-root\" build --file-watch --exec fitzbeach-backend",
    "book": "npm --workspace frontend run book",
    "book:build": "npm --workspace frontend run book:build",
    "test": "npm --workspace frontend run test",
    "dev": "npm --workspace frontend run dev",
    "dev:all": "concurrently --kill-others-on-fail --names backend,frontend \"npm:backend:watch\" \"npm:dev\"",
    "prebuild": "npm run clean",
    "build": "npm --workspace frontend run build",
    "build:pages": "./aws/scripts/pages-redirect-build.sh",
    "aws:build": "./aws/scripts/aws-build.sh",
    "aws:deploy": "./aws/scripts/aws-deploy.sh",
    "aws:destroy": "./aws/scripts/aws-destroy.sh",
    "aws:frontend:build": "./aws/scripts/aws-frontend-build.sh",
    "aws:frontend:publish": "./aws/scripts/aws-frontend-publish.sh",
    "aws:status": "./aws/scripts/aws-status.sh",
    "api:generate": "npm run backend:codegen",
    "api:check-generated": "npm run api:generate && git diff --exit-code -- frontend/src/Generated/Api",
    "review": "npm --workspace frontend run review",
    "review:fix": "npm --workspace frontend run review:fix",
    "verify": "npm run api:check-generated && npm test && npm run review && npm run backend:test && npm run book:build",
    "predeploy": "npm run verify && npm run build:pages",
    "deploy": "gh-pages -d frontend/dist"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "gh-pages": "^5.0.0",
    "shx": "^0.4.0"
  }
}

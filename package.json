{
  "name": "fitzbeach",
  "private": true,
  "scripts": {
    "clean": "shx rm -rf .parcel-cache dist dist-book",
    "backend:build": "stack --stack-yaml backend/stack.yaml build",
    "backend:codegen": "stack --stack-yaml backend/stack.yaml run fitzbeach-backend-codegen",
    "backend:ghci": "stack --stack-yaml backend/stack.yaml ghci",
    "backend:ghci:main": "stack --stack-yaml backend/stack.yaml ghci --ghci-options -e --ghci-options :main",
    "backend:run": "stack --stack-yaml backend/stack.yaml run",
    "backend:test": "stack --stack-yaml backend/stack.yaml test",
    "backend:watch": "stack --stack-yaml backend/stack.yaml build --file-watch --exec fitzbeach-backend",
    "book": "parcel book.html",
    "book:build": "parcel build book.html --dist-dir dist-book",
    "test": "elm-test",
    "dev": "parcel index.html",
    "dev:all": "concurrently --kill-others-on-fail --names backend,frontend \"npm:backend:watch\" \"npm:dev\"",
    "prebuild": "npm run clean",
    "build": "parcel build index.html",
    "build:pages": "parcel build index.html --public-url /fitzbeach/",
    "aws:build": "./scripts/aws-build.sh",
    "aws:deploy": "./scripts/aws-deploy.sh",
    "aws:destroy": "./scripts/aws-destroy.sh",
    "aws:frontend:build": "./scripts/aws-frontend-build.sh",
    "aws:frontend:publish": "./scripts/aws-frontend-publish.sh",
    "aws:status": "./scripts/aws-status.sh",
    "api:generate": "npm run backend:codegen",
    "api:check-generated": "npm run api:generate && git diff --exit-code -- src/Generated/Api",
    "review": "elm-review",
    "review:fix": "elm-review --fix-all-without-prompt",
    "verify": "npm run api:check-generated && npm test && npm run review && npm run backend:test && npm run book:build",
    "predeploy": "npm run verify && npm run build:pages",
    "deploy": "gh-pages -d dist"
  },
  "devDependencies": {
    "@parcel/transformer-elm": "^2.16.4",
    "concurrently": "^9.2.1",
    "elm": "^0.19.1-6",
    "elm-review": "^2.13.3",
    "elm-test": "^0.19.1-revision17",
    "gh-pages": "^5.0.0",
    "parcel": "^2.15.4",
    "shx": "^0.4.0"
  }
}

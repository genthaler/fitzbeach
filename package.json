{
  "name": "fitzbeach",
  "private": true,
  "scripts": {
    "clean": "shx rm -rf .parcel-cache frontend/.parcel-cache frontend/dist frontend/dist-book frontend/elm-stuff",
    "backend:build": "STACK_ROOT=\"$PWD/.stack-root\" stack --stack-yaml backend/stack.yaml build",
    "backend:codegen": "STACK_ROOT=\"$PWD/.stack-root\" stack --stack-yaml backend/stack.yaml run fitzbeach-backend-codegen",
    "backend:ghci": "STACK_ROOT=\"$PWD/.stack-root\" stack --stack-yaml backend/stack.yaml ghci",
    "backend:ghci:main": "STACK_ROOT=\"$PWD/.stack-root\" stack --stack-yaml backend/stack.yaml ghci --ghci-options -e --ghci-options :main",
    "backend:run": "STACK_ROOT=\"$PWD/.stack-root\" stack --stack-yaml backend/stack.yaml run",
    "backend:test": "STACK_ROOT=\"$PWD/.stack-root\" stack --stack-yaml backend/stack.yaml test",
    "backend:watch": "STACK_ROOT=\"$PWD/.stack-root\" stack --stack-yaml backend/stack.yaml build --file-watch --exec fitzbeach-backend",
    "book": "sh -c 'cd frontend && parcel book.html --cache-dir .parcel-cache'",
    "book:build": "sh -c 'cd frontend && parcel build book.html --cache-dir .parcel-cache --dist-dir dist-book'",
    "test": "sh -c 'cd frontend && elm-test'",
    "dev": "sh -c 'cd frontend && parcel index.html --cache-dir .parcel-cache'",
    "dev:all": "concurrently --kill-others-on-fail --names backend,frontend \"npm:backend:watch\" \"npm:dev\"",
    "prebuild": "npm run clean",
    "build": "sh -c 'cd frontend && parcel build index.html --cache-dir .parcel-cache'",
    "build:pages": "sh -c 'cd frontend && parcel build index.html --cache-dir .parcel-cache --public-url /fitzbeach/'",
    "aws:build": "./aws/scripts/aws-build.sh",
    "aws:deploy": "./aws/scripts/aws-deploy.sh",
    "aws:destroy": "./aws/scripts/aws-destroy.sh",
    "aws:frontend:build": "./aws/scripts/aws-frontend-build.sh",
    "aws:frontend:publish": "./aws/scripts/aws-frontend-publish.sh",
    "aws:status": "./aws/scripts/aws-status.sh",
    "api:generate": "npm run backend:codegen",
    "api:check-generated": "npm run api:generate && git diff --exit-code -- frontend/src/Generated/Api",
    "review": "sh -c 'cd frontend && elm-review --config review'",
    "review:fix": "sh -c 'cd frontend && elm-review --config review --fix-all-without-prompt'",
    "verify": "npm run api:check-generated && npm test && npm run review && npm run backend:test && npm run book:build",
    "predeploy": "npm run verify && npm run build:pages",
    "deploy": "gh-pages -d frontend/dist"
  },
  "devDependencies": {
    "@parcel/transformer-elm": "^2.16.4",
    "concurrently": "^9.2.1",
    "elm": "^0.19.1-6",
    "elm-review": "^2.13.3",
    "elm-test": "^0.19.1-revision17",
    "gh-pages": "^5.0.0",
    "parcel": "^2.15.4",
    "shx": "^0.4.0"
  }
}

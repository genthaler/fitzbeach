{
  "name": "fitzbeach",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "backend:build": "npm --workspace backend run build",
    "backend:codegen": "npm --workspace backend run codegen",
    "backend:ghci": "npm --workspace backend run ghci",
    "backend:ghci:main": "npm --workspace backend run ghci:main",
    "backend:run": "npm --workspace backend run run",
    "backend:test": "npm --workspace backend run test",
    "backend:watch": "npm --workspace backend run watch",
    "frontend:clean": "npm --workspace frontend run clean",
    "frontend:dev": "npm --workspace frontend run dev",
    "frontend:test": "npm --workspace frontend run test",
    "frontend:review": "npm --workspace frontend run review",
    "frontend:review:fix": "npm --workspace frontend run review:fix",
    "frontend:build": "npm --workspace frontend run build",
    "book": "npm --workspace frontend run book",
    "book:build": "npm --workspace frontend run book:build",
    "clean": "npm run frontend:clean",
    "dev:all": "concurrently --kill-others-on-fail --names backend,frontend \"npm:backend:watch\" \"npm:frontend:dev\"",
    "aws:build": "./aws/scripts/aws-build.sh",
    "aws:build:pages": "./aws/scripts/pages-redirect-build.sh",
    "aws:deploy": "./aws/scripts/aws-deploy.sh",
    "aws:destroy": "./aws/scripts/aws-destroy.sh",
    "aws:frontend:build": "./aws/scripts/aws-frontend-build.sh",
    "aws:frontend:publish": "./aws/scripts/aws-frontend-publish.sh",
    "aws:status": "./aws/scripts/aws-status.sh",
    "api:generate": "npm run backend:codegen",
    "api:check-generated": "npm run api:generate && git diff --exit-code -- frontend/src/Generated/Api",
    "verify": "npm run api:check-generated && npm run frontend:test && npm run frontend:review && npm run backend:test && npm run book:build",
    "predeploy": "npm run verify && npm run aws:build:pages",
    "deploy": "gh-pages -d frontend/dist"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "gh-pages": "^5.0.0",
    "shx": "^0.4.0"
  }
}
